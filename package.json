{
  "name": "rag",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "db:push": "turbo run db:push -F @rag/db",
    "db:studio": "turbo run db:studio -F @rag/db",
    "db:generate": "turbo run db:generate -F @rag/db",
    "db:migrate": "turbo run db:migrate -F @rag/db"
  },
  "dependencies": {
    "@rag/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rag/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.30.0"
}
